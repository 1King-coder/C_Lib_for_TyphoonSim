INVERSOR_SWITCHES switches = {
    0,0,0,0,0,0
};

HALL_INPUTS hallIns = {
    0,0,0
};

Rotation_Direction direction = CLOCKWISE;
/*End code section*/"
            init_fnc = "/*Begin code section*/
updateHallInputs(&hallIns, HallA, HallB, HallC);
resetSwitches(&switches);

switch (RotDirec) {
    case 1: {
        direction = CLOCKWISE;
        break;
    }
    case -1: {
        direction = COUNTER_CLOCKWISE;
    }
}

bldcHallSensor2phComLogic(
    &switches,
    hallIns,
    direction
    );
/*End code section*/"
            input_terminals = "int HallA;int HallB;int HallC;int RotDirec;"
