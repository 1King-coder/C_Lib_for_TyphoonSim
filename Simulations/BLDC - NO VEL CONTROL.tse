switch (RotDirec) {
    case 1: {
        direction = CLOCKWISE;
        break;
    }
    case -1: {
        direction = COUNTER_CLOCKWISE;
    }
}

bldcHallSensor2phComLogic(
    &switches,
    hallIns,
    direction
    );

Sa_top = switches.Sa_top;
Sa_bot = switches.Sa_bot;
Sb_top = switches.Sb_top;
Sb_bot = switches.Sb_bot;
Sc_top = switches.Sc_top;
